VIDEO_PATH=Videos/v2.mp4
DETECTION_MODEL_PATH=yolov8n.pt

PLATE_MODEL_PATH=models/plate_detector.pt
PLATE_CONFIDENCE=0.25
PLATE_CLASSES=0

DATABASE_URL=postgresql+psycopg://crosswalk:crosswalk@db:5432/crosswalk
SQLITE_FALLBACK_URL=sqlite:///crosswalk_violations.db
OCR_BACKEND=easyocr
OCR_USE_GPU=1

LLM_PROVIDER=mock
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

YOLO_DEVICE=0
YOLO_HALF=1

AUTHORITY_NAME=City Traffic Enforcement Unit
LOCATION_NAME=Crosswalk A
LOCATION_CODE=CW-A-01
DEFAULT_FINE_AMOUNT=150.00
OUTPUT_DIR=artifacts

MIN_PED_ACTIVE_FRAMES=6
SAFE_ENTRY_DELAY_FRAMES=20
VEHICLE_COOLDOWN_FRAMES=60
VIOLATION_CONFIRM_FRAMES=3

ENABLE_PLATE_DETECTOR=1
ENABLE_DEFERRED_OCR=1
ENABLE_WRONG_DIR=1
VIOLATION_VIDEO_PRE_SEC=3
VIOLATION_VIDEO_POST_SEC=2

LIVE_ENABLE_PLATE_DETECTOR=1
LIVE_ENABLE_OCR=1
LIVE_ENABLE_WRONG_DIR=1
LIVE_DETECT_EVERY_N_FRAMES=1

CAMERA_SOURCE=0

YANDEX_MAPS_API_KEY=your_key_here

LOCATION_LATITUDE=41.2963
LOCATION_LONGITUDE=69.2798

SEGMENTATION_ENABLED=1
SEG_MODEL_PATH=yolov8l-seg.pt
MASK_ALPHA=0.35
MASK_MIN_RATIO=0.02
SEG_EVERY_N_FRAMES=3

DIRECTION_THRESHOLD=15
ROAD_Y_MIN=350
ROAD_Y_MAX=1080
MISSING_FRAMES_FINALIZE=15
OCR_RETRY_INTERVAL=5
OCR_HIGH_CONF_THRESHOLD=0.75
OCR_MIN_ACCEPT_CONF=0.35
