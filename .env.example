VIDEO_PATH=Videos/v2.mp4
DETECTION_MODEL_PATH=yolov8n.pt
DEMO_VIDEO_SOURCE=Videos/v2.mp4

# ── Custom plate-detection model ──────────────────────────────────────────────
# Train your own YOLO model on license plates and place the .pt file in models/.
# The system automatically uses it when the file exists; if not, it falls back
# to the built-in OpenCV Haar cascade (lower accuracy, no GPU needed).
#
# Steps to use your custom model:
#   1. Copy your trained file:  models/plate_detector.pt
#   2. Set the path below (relative to project root):
PLATE_MODEL_PATH=models/plate_detector.pt
PLATE_CONFIDENCE=0.25
# Class index(es) your model uses for plates — comma-separated (e.g. 0 or 0,1)
PLATE_CLASSES=0

DATABASE_URL=postgresql+psycopg://crosswalk:crosswalk@db:5432/crosswalk
SQLITE_FALLBACK_URL=sqlite:///crosswalk_violations.db
OCR_BACKEND=easyocr
OCR_USE_GPU=1           # set to 0 to force CPU for EasyOCR

# ── LLM report generation ─────────────────────────────────────────────────────
# Set LLM_PROVIDER=anthropic and paste your key to enable AI-generated reports.
# Leave LLM_PROVIDER=mock to use the built-in template (no API key needed).
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── GPU / CUDA ────────────────────────────────────────────────────────────────
# YOLO_DEVICE=cuda:0    # force GPU; leave blank for auto-detect
# YOLO_HALF=1           # FP16 (2× speed, ~half VRAM) — CUDA only
AUTHORITY_NAME=City Traffic Enforcement Unit
LOCATION_NAME=Crosswalk A
LOCATION_CODE=CW-A-01
DEFAULT_FINE_AMOUNT=150.00
OUTPUT_DIR=artifacts

# ── Web live-processor feature flags ──────────────────────────────────────────
# Toggle these in .env and restart the detection (Stop → Start in the admin panel).
# All default to 1 (enabled). Set to 0 to disable for speed testing.
#
# Heaviest — plate YOLO / Haar cascade on every vehicle every frame:
LIVE_ENABLE_PLATE_DETECTOR=1
# Heavy — EasyOCR (runs once per vehicle ID in a background thread):
LIVE_ENABLE_OCR=1
# Light — wrong-direction detection (pure centroid math, nearly free):
LIVE_ENABLE_WRONG_DIR=1
# Skip YOLO on every N-th frame (1 = every frame, 2 = alternate, etc.):
LIVE_DETECT_EVERY_N_FRAMES=1
# Road Y-pixel band for wrong-direction; vehicles outside this range are ignored.
# Default 0–9999 covers the whole frame. Narrow to your road area if needed:
# LIVE_ROAD_Y_MIN=350
# LIVE_ROAD_Y_MAX=1080

# ── Camera source ─────────────────────────────────────────────────────────────
# Webcam index (0, 1, …) or any RTSP/HTTP URL OpenCV accepts.
# Examples:
#   CAMERA_SOURCE=0                                    # default webcam
#   CAMERA_SOURCE=rtsp://user:pass@192.168.1.100:554/stream1   # Hikvision / Dahua
#   CAMERA_SOURCE=rtsp://user:pass@192.168.1.200:554/h264Preview_01_main  # Reolink
CAMERA_SOURCE=2

# ── Yandex Maps ───────────────────────────────────────────────────────────────
# Get a key at https://developer.tech.yandex.ru/
# Without a key, violation detail pages show an external link instead of the map.
# Set only the API key value (the app builds the full script URL in templates).
YANDEX_MAPS_API_KEY=your_key_here

# ── Crosswalk GPS coordinates (used for new violations saved from main.py) ───
LOCATION_LATITUDE=41.2963
LOCATION_LONGITUDE=69.2798