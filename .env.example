VIDEO_PATH=Videos/v2.mp4
DETECTION_MODEL_PATH=yolov8n.pt

# ── Custom plate-detection model ──────────────────────────────────────────────
# Train your own YOLO model and point this to the .pt file.
# Leave blank to use the built-in Haar cascade fallback.
PLATE_MODEL_PATH=models/license_plate.pt

DATABASE_URL=postgresql+psycopg://crosswalk:crosswalk@db:5432/crosswalk
SQLITE_FALLBACK_URL=sqlite:///crosswalk_violations.db
OCR_BACKEND=easyocr
LLM_PROVIDER=mock
OPENAI_MODEL=gpt-5.4-mini
AUTHORITY_NAME=City Traffic Enforcement Unit
LOCATION_NAME=Crosswalk A
LOCATION_CODE=CW-A-01
DEFAULT_FINE_AMOUNT=150.00
OUTPUT_DIR=artifacts

# ── Camera source ─────────────────────────────────────────────────────────────
# Webcam index (0, 1, …) or any RTSP/HTTP URL OpenCV accepts.
# Examples:
#   CAMERA_SOURCE=0                                    # default webcam
#   CAMERA_SOURCE=rtsp://user:pass@192.168.1.100:554/stream1   # Hikvision / Dahua
#   CAMERA_SOURCE=rtsp://user:pass@192.168.1.200:554/h264Preview_01_main  # Reolink
CAMERA_SOURCE=0

# ── Yandex Maps ───────────────────────────────────────────────────────────────
# Get a key at https://developer.tech.yandex.ru/
# Without a key, violation detail pages show an external link instead of the map.
YANDEX_MAPS_API_KEY=

# ── Crosswalk GPS coordinates (used for new violations saved from main.py) ───
LOCATION_LATITUDE=41.2963
LOCATION_LONGITUDE=69.2798